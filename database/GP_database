import sqlite3

class GameDB:
    #DB_setup
    def __init__(self, db_name="GP_database.db"):
        self.conn = sqlite3.connect(db_name)
        self.cursor = self.conn.cursor()
        self.setup_tables()

    def setup_tables(self):
        self.cursor.execute('PRAGMA foreign_keys = ON')
    #Creating tables
        #Base table for all items
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS items (
                id TEXT PRIMARY KEY,
                type TEXT NOT NULL,
                name TEXT NOT NULL,
                image_path TEXT,
                price INTEGER DEFAULT 0,
                description TEXT
            )
        ''')

        #Weapons sub table
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS weapons (
                item_id TEXT PRIMARY KEY,
                weapon_class TEXT,       
                durability INT,
                range INT,            
                projectile_speed INT, 
                cooldown INT,
                spread_degrees INT,
                cone_degrees INT,     

                FOREIGN KEY (item_id) REFERENCES items(id) ON DELETE CASCADE
            )
        ''')

        #Consumables sub table
        #TODO add effects table

        self.conn.commit()
        print("Database setup complete.")

    def close(self):
        self.conn.close()
